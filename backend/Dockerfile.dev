FROM node:22-alpine AS base
RUN corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /app

COPY package.json ./
RUN pnpm install

COPY prisma.config.ts ./
COPY prisma ./prisma
RUN pnpm db:generate

COPY . .

# Startup: push schema, regenerate Prisma client (Prisma 7 `db push`
# does NOT regenerate the client), then start the dev server
RUN printf '#!/bin/sh\nset -e\necho "Pushing database schema..."\npnpm db:push\necho "Regenerating Prisma client..."\npnpm db:generate\necho "Starting dev server..."\nexec pnpm dev\n' > /app/start.sh && chmod +x /app/start.sh

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:3000/health || exit 1

CMD ["/app/start.sh"]
