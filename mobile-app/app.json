{
  "expo": {
    "name": "Qatha",
    "slug": "qatha",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "qatha",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7FAFC"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.qatha.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F7FAFC"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.qatha.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "apiUrl": "https://api-qatha.chesty.dev",
      "eas": {
        "projectId": "07ac53ad-e610-4fc9-b1c3-1367e6757a1a"
      }
    }
  }
}
